# Sensitive Django API and MySQL database credentials. secrets.yaml should be inside the k8s/ folder
apiVersion: v1
kind: Secret
metadata:
  name: api-secrets
type: Opaque
stringData:
  SECRET_KEY: "PLACEHOLDER_FOR_DJANGO_KEY"
  DB_PASSWORD: "PLACEHOLDER_FOR_DB_PASSWORD"
  MYSQL_ROOT_PASSWORD: "PLACEHOLDER_FOR_ROOT_PASSWORD"